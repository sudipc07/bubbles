# Bubbles — environment template. Copy to .env on the server and fill in.

NODE_ENV=production
PORT=3001
PUBLIC_URL=https://bubbles.work

# Postgres (local on EC2)
DATABASE_URL=postgresql://bubbles:CHANGE_ME@127.0.0.1:5432/bubbles

# Session
SESSION_SECRET=CHANGE_ME_32_BYTES_RANDOM

# Email (SES) — uses EC2 instance role for auth, no AWS keys needed here
EMAIL_PROVIDER=ses
AWS_REGION=ap-south-1
SES_FROM_EMAIL=Bubbles <no-reply@resume-folio.app>

# S3 (object storage)
S3_BUCKET=bubbles
S3_REGION=ap-south-1

# LLM
OPENAI_API_KEY=sk-CHANGE_ME

# Cost guardrails
DEFAULT_MONTHLY_COST_CEILING_USD=20
